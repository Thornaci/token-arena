{
  "name": "token-arena",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "A gamified, open-source web app that teaches developers how LLMs actually work — tokens, context windows, instruction hierarchy, context rot.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "i18n:check": "node scripts/check-i18n.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/react": "^1.1.0",
    "astro": "^7.0.7",
    "gpt-tokenizer": "^3.4.0",
    "nanostores": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@inlang/paraglide-js": "^2.21.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
