{
  "name": "token-arena",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "A gamified, open-source web app that teaches developers how LLMs actually work — tokens, context windows, instruction hierarchy, context rot.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "i18n:check": "node scripts/check-i18n.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@huggingface/transformers": "^4.2.0",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/react": "^1.1.0",
    "astro": "^7.0.7",
    "gpt-tokenizer": "^3.4.0",
    "motion": "^12.42.2",
    "nanostores": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@inlang/paraglide-js": "^2.21.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
