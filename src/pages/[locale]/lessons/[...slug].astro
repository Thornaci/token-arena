---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import LocaleSwitcher from '@/components/ui/LocaleSwitcher.astro';
import ContextInspector from '@/components/inspector/ContextInspector.tsx';
import LessonShell from '@/components/lesson/LessonShell.tsx';
import HudBadge from '@/components/hud/HudBadge.tsx';
import SettingsMenu from '@/components/hud/SettingsMenu.tsx';
import { nextLesson, sortLessons, type LessonMeta } from '@/lib/curriculum';
import { LOCALES } from '@/lib/locales';
import { lessonText } from '@/lib/lessonText';

export async function getStaticPaths() {
  const entries = await getCollection('lessons');
  const metas: LessonMeta[] = entries.map((entry) => ({
    id: entry.data.id,
    slug: entry.id,
    module: entry.data.module,
    order: entry.data.order,
    titleKey: entry.data.titleKey,
    xp: entry.data.xp,
  }));
  const sorted = sortLessons(metas);

  return LOCALES.flatMap((locale) =>
    entries.map((entry) => ({
      params: { locale, slug: entry.id },
      props: {
        lesson: entry.data,
        next: nextLesson(sorted, entry.data.id),
        totalLessons: entries.length,
      },
    })),
  );
}

const { locale } = Astro.params;
const { lesson, next, totalLessons } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const mapHref = `${base}/${locale}/`;
const nextHref = next ? `${base}/${locale}/lessons/${next.slug}/` : mapHref;
const title = lessonText(lesson.titleKey, locale);
---

<Base locale={locale} title={`${title} · Token Arena`}>
  <div class="mx-auto flex min-h-dvh max-w-6xl flex-col px-5 sm:px-8">
    <header class="flex flex-wrap items-center justify-between gap-x-3 gap-y-2 py-4">
      <a href={mapHref} class="font-mono text-sm text-(--color-faint) hover:text-(--color-ink)">
        ← Token_Arena
      </a>
      <div class="flex items-center gap-3">
        <HudBadge client:load locale={locale} totalLessons={totalLessons} />
        <SettingsMenu client:load locale={locale} />
        <LocaleSwitcher locale={locale} />
      </div>
    </header>

    <div
      class:list={[
        'grid grid-cols-1 gap-6 pb-28 lg:pb-16',
        lesson.inspector && 'lg:grid-cols-[minmax(0,1fr)_360px]',
      ]}
    >
      <main>
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-(--color-faint)">
          {lesson.id}
        </p>
        <h1 class="mt-1 font-display text-3xl font-bold text-(--color-ink)">{title}</h1>
        <p class="mt-2 max-w-2xl text-(--color-dim)">{lessonText(lesson.objectiveKey, locale)}</p>

        <div class="mt-8">
          <LessonShell
            client:load
            lesson={lesson}
            locale={locale}
            nextHref={nextHref}
            nextIsMap={!next}
          />
        </div>
      </main>

      {
        lesson.inspector && (
          <aside class="fixed inset-x-0 bottom-0 z-40 px-2 pb-2 lg:static lg:px-0 lg:pb-0">
            <div class="lg:sticky lg:top-6 lg:max-h-[calc(100dvh-3rem)]">
              <ContextInspector client:load locale={locale} />
            </div>
          </aside>
        )
      }
    </div>
  </div>
</Base>
