---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import LocaleSwitcher from '@/components/ui/LocaleSwitcher.astro';
import HudBadge from '@/components/hud/HudBadge.tsx';
import WorldMap from '@/components/map/WorldMap.tsx';
import { MODULES } from '@/content/modules';
import type { LessonMeta } from '@/lib/curriculum';
import { LOCALES } from '@/lib/locales';
import * as m from '@/paraglide/messages';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;

const entries = await getCollection('lessons');
const lessons: LessonMeta[] = entries.map((entry) => ({
  id: entry.data.id,
  slug: entry.id,
  module: entry.data.module,
  order: entry.data.order,
  titleKey: entry.data.titleKey,
  xp: entry.data.xp,
}));
---

<Base locale={locale} title={m.app_title()} description={m.app_description()}>
  <div class="mx-auto flex min-h-dvh max-w-4xl flex-col px-5 sm:px-8">
    <header class="flex flex-wrap items-center justify-between gap-x-4 gap-y-2 py-5">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-(--color-faint)">
        {m.home_kicker()}
      </p>
      <div class="flex items-center gap-3">
        <HudBadge client:load locale={locale} totalLessons={lessons.length} />
        <LocaleSwitcher locale={locale} />
      </div>
    </header>

    <section class="py-10 sm:py-14">
      <h1
        class="font-display text-5xl font-bold tracking-tight text-(--color-ink) sm:text-6xl"
      >
        Token<span class="text-(--color-phosphor) text-glow">_</span>Arena
      </h1>
      <p class="mt-3 font-mono text-lg text-(--color-phosphor)">{m.app_tagline()}</p>
      <p class="mt-4 max-w-xl text-(--color-dim)">{m.home_intro()}</p>
    </section>

    <main class="pb-16">
      <WorldMap client:load locale={locale} modules={MODULES} lessons={lessons} />
    </main>

    <footer
      class="mt-auto flex items-center justify-between border-t border-(--color-line) py-6 font-mono text-xs text-(--color-faint)"
    >
      <span>MIT · Token Arena</span>
      <a
        href="https://github.com/Thornaci/token-arena"
        class="underline decoration-dotted underline-offset-4 hover:text-(--color-ink)"
        >{m.footer_source()}</a
      >
    </footer>
  </div>
</Base>
