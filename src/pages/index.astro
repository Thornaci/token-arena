---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { DEFAULT_LOCALE, LOCALES } from '@/lib/locales';

const fallbackUrl = getRelativeLocaleUrl(DEFAULT_LOCALE);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline define:vars={{ base, localeList: [...LOCALES], fallback: DEFAULT_LOCALE }}>
      var locale = fallback;
      try {
        var stored = localStorage.getItem('ta:locale');
        if (localeList.indexOf(stored) !== -1) locale = stored;
      } catch (e) {
        /* storage unavailable — fall back to the default locale */
      }
      location.replace(base + '/' + locale + '/');
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${fallbackUrl}`} />
    </noscript>
    <link rel="canonical" href={new URL(fallbackUrl, Astro.site)} />
    <title>Token Arena</title>
  </head>
  <body>
    <a href={fallbackUrl}>Continue to Token Arena</a>
  </body>
</html>
